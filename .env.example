## AutoSocial AI environment template
## Copy to .env and fill in values

# App
APP_ENV=dev
LOG_LEVEL=INFO
WEB_CONCURRENCY=2
GUNICORN_TIMEOUT=60
GUNICORN_GRACEFUL_TIMEOUT=30
SECRET_KEY=

# Watcher
# Full path on your host when running locally; inside Docker this is /watched
WATCH_PATH=

# Database (Docker Compose default uses Postgres; local dev falls back to sqlite)
# Example for local Postgres:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/autosocial
DATABASE_URL=
DB_SSLMODE=
DB_ECHO=false

# AI providers
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# X (Twitter)
X_BEARER_TOKEN=
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_URN=
LINKEDIN_AUTHOR_URN=
